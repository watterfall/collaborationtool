{
  "name": "@collaborationtool/editor-core",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./schema": {
      "types": "./src/schema.ts",
      "default": "./src/schema.ts"
    },
    "./commit": {
      "types": "./src/commit.ts",
      "default": "./src/commit.ts"
    },
    "./sync": {
      "types": "./src/sync/index.ts",
      "default": "./src/sync/index.ts"
    }
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "node --test --import tsx tests/*.test.ts"
  },
  "dependencies": {
    "@collaborationtool/permissions": "workspace:*",
    "@collaborationtool/schema": "workspace:*",
    "@tiptap/core": "^2.10.3",
    "@tiptap/extension-bold": "^2.10.3",
    "@tiptap/extension-collaboration": "^2.10.3",
    "@tiptap/extension-document": "^2.10.3",
    "@tiptap/extension-heading": "^2.10.3",
    "@tiptap/extension-italic": "^2.10.3",
    "@tiptap/extension-paragraph": "^2.10.3",
    "@tiptap/extension-text": "^2.10.3",
    "@tiptap/pm": "^2.10.3",
    "@tiptap/react": "^2.10.3",
    "katex": "^0.16.11",
    "react": "^19.0.0",
    "uuid": "^11.0.3",
    "y-indexeddb": "^9.0.12",
    "y-prosemirror": "^1.2.15",
    "y-protocols": "^1.0.6",
    "yjs": "^13.6.21"
  },
  "devDependencies": {
    "@types/katex": "^0.16.7",
    "@types/node": "^22.10.2",
    "@types/react": "^19.2.0",
    "@types/uuid": "^10.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
